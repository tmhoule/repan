DATABASE_URL="postgresql://repan:repan_dev@localhost:5432/repan"
NEXT_PUBLIC_APP_NAME="Repan"

# Security: Session signing secret (REQUIRED for production)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET="your-session-secret-here-generate-random-64-char-hex-string"

# Security: Cron job authentication
CRON_SECRET="your-cron-secret-here"

# Set to "true" if accessing the app over HTTP on a LAN (not HTTPS)
DISABLE_SECURE_COOKIES="true"
